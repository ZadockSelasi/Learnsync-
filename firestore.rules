rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "zadockselasi7@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if (isOwner(userId) && request.resource.data.uid == resource.data.uid && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    match /roadmaps/{roadmapId} {
      allow read: if isDocOwner() || isAdmin();
      allow list: if isDocOwner() || isAdmin();
      allow create: if isRequestOwner();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /companies/{companyId} {
      allow read: if true; // Publicly readable for the directory
      allow create: if true; // Anyone can submit a company registration
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /quizzes/{quizId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    match /flashcards/{flashcardId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    match /exams/{examId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    match /studySessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    match /stickyNotes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isRequestOwner();
      allow update: if isDocOwner() && uidNotModified();
      allow delete: if isDocOwner();
    }
    
    match /careerProfiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
  }
}
